# Copy this file to .env and fill in real values locally.
# Keep production secrets in your hosting provider's environment settings.

# Database Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/shopsphere

# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret

# Cloudinary Configuration (for image uploads)
CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret

# Server Configuration
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000

# Application Settings
PAGINATION_LIMIT=12

# Production CORS:
# FRONTEND_URL=https://your-exact-frontend-domain.com
# Production frontend build:
# VITE_API_URL=https://shopsphere-u4s8.onrender.com

# PayPal
PAYPAL_CLIENT_ID=replace_with_paypal_client_id
PAYPAL_APP_SECRET=replace_with_paypal_app_secret
# PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# Optional: Email Service (for notifications)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_email_password

# Optional: Redis (for caching)
# REDIS_URL=redis://localhost:6379

# Security Configuration
# SESSION_SECRET=your_session_secret_here
# ENCRYPTION_KEY=your_encryption_key_here
